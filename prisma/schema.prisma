generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String
  lastName  String
  email     String  @unique
  phone     String?
  role      String?

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  status    String @default("PENDING")

  @@map("leads")
}

model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name    String
  siret   String?  @unique
  website String?
  sector  String
  size    String
  city    String?

  leads Lead[]

  @@map("companies")
}

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  needs           String
  description     String
  budget          String?
  timeline        String?
  currentStack    String?
  teamSize        Int?
  preferredDate   DateTime?
  additionalNotes String?

  leads Lead[]

  @@map("projects")
}